---
import Header from '../components/Header.astro';
import MovingStrip from '../components/MovingStrip.astro';
import Footer from '../components/Footer.astro';
import RegistrationPopup from '../components/RegistrationPopup.astro';

interface Props {
  title: string;
  description: string;
  hideSignupPopup?: boolean;
  hideEditBar?: boolean;
}

const { title, description, hideSignupPopup = false, hideEditBar = false } = Astro.props;
---
<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="skin/sport5_mockup.css" />
  <link rel="icon" type="image/x-icon" href="skin/design/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="skin/design/favicon-32.png" />
  <link rel="apple-touch-icon" href="skin/design/apple-touch-icon.png" />
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7H73T59SQH"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-7H73T59SQH');
  </script>
  <slot name="head" />
</head>
<body data-hide-edit-bar={hideEditBar ? 'true' : 'false'}>
  <Header />
  <MovingStrip />
  <slot />
  <Footer />
  {!hideSignupPopup && <RegistrationPopup />}
  <script>
    import { supabase } from '../lib/supabase.js';
    import { initSportContent } from '../lib/sportContent.js';
    import { getEditContext, mountEditBar, mountAdSlotEditor } from '../lib/inlineEditor.js';

    initSportContent();

    if (document.body.dataset.hideEditBar !== 'true') {
      getEditContext().then(mountEditBar);
    }

    async function loadAds() {
      const adEls = document.querySelectorAll('[data-ad-slot]');
      if (!adEls.length) return;
      const { data } = await supabase.from('site_ads').select('*');
      const bySlot = Object.fromEntries((data || []).map((row) => [row.slot, row]));

      const ctx = await getEditContext();
      const isAdmin = ctx?.role === 'admin';

      adEls.forEach((adEl) => {
        const slot = adEl.dataset.adSlot;
        const row = bySlot[slot];
        adEl.innerHTML = '';
        if (row?.image_url) {
          const img = document.createElement('img');
          img.src = row.image_url;
          img.alt = row.caption || '';
          if (row.link_url) {
            const link = document.createElement('a');
            link.href = row.link_url;
            link.target = '_blank';
            link.rel = 'noopener';
            link.appendChild(img);
            adEl.appendChild(link);
          } else {
            adEl.appendChild(img);
          }
        } else {
          adEl.textContent = row?.caption || (slot === 'left' ? 'פרסומת שמאל' : 'פרסומת ימין');
        }

        if (isAdmin) mountAdSlotEditor(adEl, slot, row, loadAds);
      });
    }
    loadAds();
  </script>
</body>
</html>
