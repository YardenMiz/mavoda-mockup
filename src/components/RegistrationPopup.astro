<div id="signup-popup" class="signup-popup" hidden>
  <div class="signup-popup-box">
    <button type="button" class="signup-popup-close" aria-label="סגור">&times;</button>
    <h2>הצטרפו אלינו!</h2>
    <p>השאירו פרטים ונחזור אליכם עם כל המידע על הליגות והענפים</p>
    <form id="signup-popup-form">
      <input type="text" name="full_name" placeholder="שם מלא" required>
      <input type="tel" name="phone" placeholder="טלפון" required>
      <input type="email" name="email" placeholder="דוא&quot;ל" required>
      <button type="submit">שליחה</button>
    </form>
    <p id="signup-popup-status" role="status"></p>
  </div>
</div>

<style>
  .signup-popup {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 2000;
    width: calc(100% - 40px);
    max-width: 320px;
  }
  .signup-popup[hidden] {
    display: none;
  }
  .signup-popup-box {
    background: #fff;
    padding: 24px 20px 20px;
    border-radius: 16px;
    position: relative;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }
  .signup-popup-close {
    position: absolute;
    top: 8px;
    left: 10px;
    background: none;
    border: none;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    color: #888;
  }
  .signup-popup-close:hover {
    color: #000;
  }
  .signup-popup-box h2 {
    margin: 0 0 8px;
  }
  .signup-popup-box p {
    margin: 0 0 20px;
    color: #555;
  }
  #signup-popup-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  #signup-popup-form input {
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
  }
  #signup-popup-form button {
    padding: 10px;
    background: #3ac41e;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }
  #signup-popup-form button:hover {
    background: #2a9e15;
  }
  #signup-popup-status {
    margin: 12px 0 0;
    font-size: 0.9rem;
  }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  // Tracked per-tab (sessionStorage) rather than forever (localStorage): a
  // fresh site visit should always show the popup once, then it keeps
  // reappearing every REAPPEAR_MS while that visit continues, even across
  // page navigations within the same tab.
  const DISMISSED_AT_KEY = 'mavoda_signup_popup_dismissed_at';
  const REAPPEAR_MS = 10 * 60 * 1000;

  const popup = document.getElementById('signup-popup');
  const form = document.getElementById('signup-popup-form');
  const status = document.getElementById('signup-popup-status');
  const closeBtn = popup.querySelector('.signup-popup-close');
  let reappearTimer;

  function show() {
    popup.hidden = false;
  }

  function scheduleReappear(delay) {
    clearTimeout(reappearTimer);
    reappearTimer = setTimeout(show, delay);
  }

  function dismiss() {
    popup.hidden = true;
    sessionStorage.setItem(DISMISSED_AT_KEY, String(Date.now()));
    scheduleReappear(REAPPEAR_MS);
  }

  const dismissedAt = Number(sessionStorage.getItem(DISMISSED_AT_KEY) || 0);
  const elapsed = Date.now() - dismissedAt;
  if (!dismissedAt || elapsed >= REAPPEAR_MS) {
    show();
  } else {
    scheduleReappear(REAPPEAR_MS - elapsed);
  }

  closeBtn.addEventListener('click', dismiss);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !popup.hidden) dismiss();
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const submitBtn = form.querySelector('button');
    submitBtn.disabled = true;
    status.textContent = 'שולח...';

    const { error } = await supabase.from('registrations').insert({
      full_name: data.get('full_name'),
      phone: data.get('phone'),
      email: data.get('email'),
    });

    if (error) {
      console.error('signup popup insert error:', error);
      status.textContent = 'שגיאה בשליחה, נסו שוב מאוחר יותר.';
      submitBtn.disabled = false;
      return;
    }

    status.textContent = 'תודה! נחזור אליכם בהקדם.';
    setTimeout(dismiss, 1500);
  });
</script>
