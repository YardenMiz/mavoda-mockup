---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`צור קשר — בית ספורט`} description={`יצירת קשר עם העמותה לספורט מרחב חיפה והצפון — פרטי התקשרות ופנייה לרכזי הענפים.`}>
<Fragment slot="head">
  <style>
    .contact-section {
      margin: 2rem 0;
      padding: 2rem;
      background: #f5f5f5;
      border-radius: 8px;
    }
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 500px;
    }
    .contact-form input,
    .contact-form textarea {
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
    }
    .contact-form button {
      padding: 0.75rem;
      background: #007bff;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
    }
    .contact-form button:hover {
      background: #0056b3;
    }
    .contact-info {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 2rem;
    }
    .info-item h4 {
      margin-top: 0;
      color: #333;
    }
  </style>
</Fragment>

<main class="container main-grid"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder">פרסומת שמאל</div></aside><div class="main-content">
    <section class="hero"> 
      <img src="skin/design/hero.jpg" alt="כותרת" class="hero-img" width="851" height="315">
      <div class="hero-overlay">
        <h1 class="hero-title">צור קשר</h1>
        <p class="hero-lead">אנחנו כאן בשבילך</p>
      </div>
    </section>

    <div class="contact-section">
      <h2> דרכי יצירת קשר</h2>
      
      <div class="contact-info">
        <div class="info-item">
          <h4>כתובת</h4>
          <p>רחוב חורי 2<br>חיפה 3311306<br>ישראל</p>
        </div>
        <div class="info-item">
          <h4>טלפון ודוא"ל</h4>
          <p>טלפון: 04-8620820<br>דוא"ל: office@mavoda-haifa.org.il<br>פקס: 04-8620821</p>
        </div>
      </div>

      <h3 style="margin-top: 2rem;">שלח לנו הודעה</h3>
      <form class="contact-form" id="contact-form">
        <input type="text" placeholder="שם הארגון" name="organization_name">
        <input type="text" placeholder="שם מלא" name="full_name" required>
        <input type="tel" placeholder="נייד" name="mobile" required>
        <input type="email" placeholder="כתובת דואר אלקטרוני" name="email" required>
        <input type="text" placeholder="נושא" name="subject">
        <textarea placeholder="הודעתך..." rows="6" name="message" required></textarea>
        <button type="submit">שלח הודעה</button>
      </form>
      <p id="contact-form-status" role="status"></p>
    </div>

  </div><aside class="side-panel"><div class="ad-placeholder">פרסומת ימין</div></aside></div></main>

<script>
  import { supabase } from '../lib/supabase.js';

  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-form-status');

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const submitBtn = form.querySelector('button');
    submitBtn.disabled = true;
    status.textContent = 'שולח...';

    const { error } = await supabase.from('contact_messages').insert({
      organization_name: data.get('organization_name') || null,
      full_name: data.get('full_name'),
      mobile: data.get('mobile'),
      email: data.get('email'),
      subject: data.get('subject') || null,
      message: data.get('message'),
    });

    if (error) {
      console.error('contact form insert error:', error);
      status.textContent = 'שגיאה בשליחה, נסו שוב מאוחר יותר.';
      submitBtn.disabled = false;
      return;
    }

    status.textContent = 'ההודעה נשלחה בהצלחה, נחזור אליך בהקדם.';
    form.reset();
    submitBtn.disabled = false;
  });
</script>
</BaseLayout>
