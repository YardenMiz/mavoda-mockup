---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`חדשות — בית ספורט`} description={`חדשות ועדכונים מהעמותה לספורט מרחב חיפה והצפון — תוצאות, כתבות ועדכוני ליגות.`}>
<main class="container main-grid"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder">פרסומת שמאל</div></aside><div class="main-content">
    <section class="hero">
      <img src="skin/design/top_pic00.jpg" alt="כותרת" class="hero-img" width="1920" height="293">
      <div class="hero-overlay">
        <h1 class="hero-title">חדשות</h1>
        <p class="hero-lead">עדכונים והידיעות האחרונות מבית הספורט</p>
      </div>
    </section>

    <aside class="side-articles">
      <h3>מאמרים אחרונים</h3>
      <div class="side-item">
        <img src="skin/design/444.jpg" alt="" width="1920" height="293" loading="lazy">
        <div class="side-text"><strong>שיחה עם המאמן</strong><br>תמצית קצרה של הכתבה.</div>
      </div>
      <div class="side-item">
        <img src="skin/design/555.jpg" alt="" width="1920" height="293" loading="lazy">
        <div class="side-text"><strong>סיכום המחזור</strong><br>תמצית קצרה של הכתבה.</div>
      </div>
      <a class="more" href="#">עוד חדשות</a>
    </aside>

    <section class="cards">
      <article class="card">
        <img src="skin/design/hero.jpg" alt="" width="851" height="315" loading="lazy">
        <h4>כתבה מרכזית 1</h4>
        <p>תקציר קצר של כתבת החדשות הממוקמת כאן.</p>
      </article>
      <article class="card">
        <img src="skin/design/666.jpg" alt="" width="1920" height="293" loading="lazy">
        <h4>כתבה מרכזית 2</h4>
        <p>תקציר קצר של הכתבה השנייה.</p>
      </article>
      <article class="card">
        <img src="skin/design/444.jpg" alt="" width="1920" height="293" loading="lazy">
        <h4>כתבה מרכזית 3</h4>
        <p>תקציר קצר של הכתבה השלישית.</p>
      </article>
      <article class="card">
        <img src="skin/design/555.jpg" alt="" width="1920" height="293" loading="lazy">
        <h4>כתבה מרכזית 4</h4>
        <p>תקציר קצר של הכתבה הרביעית.</p>
      </article>
    </section>

  </div><aside class="side-panel"><div class="ad-placeholder">פרסומת ימין</div></aside></div></main>
</BaseLayout>
