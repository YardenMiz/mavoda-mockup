---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`תקנונים - העמותה לספורט - מרחב חיפה והצפון`} description={`תקנוני הליגות של כל ענפי הספורט בעמותה לספורט מרחב חיפה והצפון.`}>
<Fragment slot="head">
  <style>
    .page-shell {
      zoom: 0.75;
    }
    .header-actions {
      text-align: center;
    }
    .header-actions .search {
      width: 150px;
      background: #3ac41e;
      border: 1px solid #024616;
      color: #000;
      border-radius: 20px;
      padding: 8px 12px;
      font-size: 13px;
    }
    .header-actions .search option {
      color: #000;
      background: #fff;
    }
    .dropdown-menu {
      display: none !important;
    }
    .regulations-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr); 
      gap: 20px;
      margin: 30px 0;
    }
    .regulation-card {
      background: #fff;
      padding: 48px;
      border-radius: 24px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .regulation-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    .regulation-card img {
      width: 100px; /* Increased from 80px */
      height: 100px; /* Increased from 80px */
      object-fit: cover;
      border-radius: 10px;
      margin-bottom: 16px;
    }
    .regulation-card h3 {
      margin: 0 0 12px;
      font-size: 18px;
      font-weight: 600;
      color: #1f2937;
    }
    .regulation-card .btn {
      display: inline-block;
      background: #3ac41e;
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.3s ease;
    }
    .regulation-card .btn:hover {
      background: #2a9e15;
    }
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      align-items: center;
      justify-content: center;
    }
    .modal-content {
      background-color: #fff;
      margin: 0;
      padding: 30px;
      border-radius: 12px;
      width: 80%;
      max-width: 600px;
      max-height: 80vh;
      overflow-y: auto;
      position: relative;
    }
    .close {
      color: #aaa;
      float: right;
      font-size: 28px;
      font-weight: bold;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      line-height: 1;
      font-family: inherit;
    }
    .close:hover {
      color: #000;
    }
  </style>
</Fragment>

<main class="container"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="left"></div></aside><div class="main-content">
