    </section>
  </div><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="right"></div></aside></div></main>

  <!-- Modal -->
  <div id="regulationModal" class="modal">
    <div class="modal-content">
      <button type="button" class="close" aria-label="סגור">&times;</button>
      <h2 id="modalTitle"></h2>
      <div id="modalContent">
        <p>תוכן התקנון יוצג כאן...</p>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase.js';

    // Modal functionality
    const modal = document.getElementById('regulationModal');
    const modalTitle = document.getElementById('modalTitle');
    const modalContent = document.getElementById('modalContent');
    const closeBtn = document.getElementsByClassName('close')[0];

    // Fallback content, used only if the Supabase fetch below fails or a
    // sport has no regulations row yet.
    const regulations = {
      'כדורגל': {
        title: 'תקנון כדורגל',
        content: `
          <h3>כללי המשחק</h3>
          <p>המשחק מתנהל על פי חוקי FIFA הבינלאומיים.</p>
          <h3>זכאות השתתפות</h3>
          <p>כל שחקן מעל גיל 16 רשאי להשתתף בליגות הבוגרים.</p>
          <h3>כללי התנהגות</h3>
          <p>איסור על אלימות, קללות והתנהגות לא ספורטיבית.</p>
        `
      },
      'כדורסל': {
        title: 'תקנון כדורסל',
        content: `
          <h3>כללי המשחק</h3>
          <p>המשחק מתנהל על פי חוקי FIBA.</p>
          <h3>זמני משחק</h3>
          <p>כל משחק נמשך 4 רבעים של 10 דקות כל אחד.</p>
          <h3>חוקי עבירות</h3>
          <p>5 עבירות לשחקן = הוצאה מהמשחק.</p>
        `
      },
      'כדורעף': {
        title: 'תקנון כדורעף',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק עד 3 סטים, כל סט עד 25 נקודות.</p>
          <h3>חוקי ההגשה</h3>
          <p>כל קבוצה רשאית לבצע 3 מגעים בכדור.</p>
        `
      },
      'כדורשת': {
        title: 'תקנון כדורשת',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק בין שתי קבוצות של 7 שחקנים כל אחת.</p>
          <h3>זמני משחק</h3>
          <p>2 מחציות של 30 דקות כל אחת.</p>
        `
      },
      'טניס': {
        title: 'תקנון טניס',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק עד 3 סטים, כל סט עד 6 משחקונים.</p>
          <h3>חוקי הניקוד</h3>
          <p>0, 15, 30, 40, משחקון.</p>
        `
      },
      'שחייה': {
        title: 'תקנון שחייה',
        content: `
          <h3>כללי התחרות</h3>
          <p>תחרויות על פי תקני FINA.</p>
          <h3>סגנונות שחייה</h3>
          <p>חופשי, גב, חזה, פרפר.</p>
        `
      },
      'ריצה': {
        title: 'תקנון ריצה',
        content: `
          <h3>כללי התחרות</h3>
          <p>מרוצים למרחקים שונים.</p>
          <h3>חוקי הזינוק</h3>
          <p>איסור זינוק מוקדם.</p>
        `
      },
      'אופני הרים': {
        title: 'תקנון אופני הרים',
        content: `
          <h3>כללי הבטיחות</h3>
          <p>חובה על קסדה ואביזרי בטיחות.</p>
          <h3>מסלולי הרכיבה</h3>
          <p>מסלולים מסומנים בלבד.</p>
        `
      },
      'פאדל': {
        title: 'תקנון פאדל',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק דומה לטניס אך עם קירות.</p>
          <h3>חוקי הניקוד</h3>
          <p>עד 3 סטים, כל סט עד 6 משחקונים.</p>
        `
      },
      'טניס שולחן': {
        title: 'תקנון טניס שולחן',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק עד 11 נקודות למשחקון.</p>
          <h3>חוקי ההגשה</h3>
          <p>הגשה לסירוגין כל 2 נקודות.</p>
        `
      },
      'באולינג': {
        title: 'תקנון באולינג',
        content: `
          <h3>כללי המשחק</h3>
          <p>10 פריימים למשחק, 2 זריקות לכל פריימ.</p>
          <h3>חוקי הסטרייק</h3>
          <p>הפלת כל 10 הפינים בזריקה אחת.</p>
        `
      },
      'סנוקר': {
        title: 'תקנון סנוקר',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק על שולחן עם 21 כדורים.</p>
          <h3>חוקי הניקוד</h3>
          <p>צבעים שונים עם ערכי נקודות שונים.</p>
        `
      },
      'שחמט': {
        title: 'תקנון שחמט',
        content: `
          <h3>כללי המשחק</h3>
          <p>המשחק מתנהל על פי חוקי פיד"ה (FIDE) הבינלאומיים.</p>
          <h3>מטרת המשחק</h3>
          <p>להכניס את מלך היריב למצב של מט.</p>
        `
      },
      'שש בש': {
        title: 'תקנון שש בש',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק אסטרטגיה עם קוביות.</p>
          <h3>חוקי התנועה</h3>
          <p>הזזת כלים לפי מספר הקוביות.</p>
        `
      },
      'שש בש': {
        title: 'תקנון שש בש',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק אסטרטגיה עם קוביות.</p>
          <h3>חוקי התנועה</h3>
          <p>הזזת כלים לפי מספר הקוביות.</p>
        `
      },
      'ירי ספורטיבי': {
        title: 'תקנון ירי ספורטיבי',
        content: `
          <h3>כללי הבטיחות</h3>
          <p>חובה על משקפי מגן ואטמי אוזניים.</p>
          <h3>חוקי התחרות</h3>
          <p>ירי למרחקים קבועים.</p>
        `
      },
      'קטרגל': {
        title: 'תקנון קטרגל',
        content: `
          <h3>כללי המשחק</h3>
          <p>משחק קבוצתי על מגרש מיוחד.</p>
          <h3>חוקי הציוד</h3>
          <p>מגלשיים ומחבטים מיוחדים.</p>
        `
      },
      'סאפ תחרויות': {
        title: 'תקנון סאפ תחרויות',
        content: `
          <h3>כללי התחרות</h3>
          <p>גלישת עמידה על גלשן.</p>
          <h3>חוקי הבטיחות</h3>
          <p>חגורת הצלה חובה.</p>
        `
      }
    };

    // Load live regulations from Supabase so edits made in /admin show up
    // here immediately, without needing a new deploy.
    let regsBySlug = {};
    try {
      const { data } = await supabase.from('sport_regulations').select('sport_slug, body');
      if (data) {
        for (const row of data) regsBySlug[row.sport_slug] = row.body;
      }
    } catch (e) {
      // Supabase unreachable: fall through to the static fallback content below.
    }

    // Add click event to all regulation buttons
    document.querySelectorAll('.regulation-card').forEach(card => {
      const btn = card.querySelector('.btn');
      const slug = card.dataset.slug;
      const sportName = card.querySelector('h3').textContent;
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const liveBody = regsBySlug[slug];
        const fallback = regulations[sportName];
        if (!liveBody && !fallback) return;
        modalTitle.textContent = `תקנון ${sportName}`;
        modalContent.innerHTML = liveBody || fallback.content;
        modal.style.display = 'flex';
      });
    });

    // Close modal when clicking X
    closeBtn.onclick = function() {
      modal.style.display = 'none';
    }

    // Close modal when clicking outside
    window.onclick = function(event) {
      if (event.target == modal) {
        modal.style.display = 'none';
      }
    }

    // Close modal with Escape key (keyboard accessibility)
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape' && modal.style.display === 'flex') {
        modal.style.display = 'none';
      }
    });
  </script>
</BaseLayout>
