---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`באולינג - העמותה לספורט`} description={`ליגת הבאולינג של העמותה לספורט מרחב חיפה והצפון — משחקים קרובים, תוצאות אחרונות וגלריה.`}>
<main class="container"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder">פרסומת שמאל</div></aside><div class="main-content"><a href="index.html" class="back-link">← חזרה</a><div class="sport-detail-header"><h1>באולינג</h1></div><div class="coordinator-info"><div class="coordinator-name">רכז: דוד כהן</div><div class="coordinator-phone">טלפון: 050-1234567</div></div><div class="tabs-nav"><button class="tab-button active" data-tab="upcoming">משחקים הבאים</button><button class="tab-button active" data-tab="results">תוצאות</button><button class="tab-button" data-tab="gallery">גלריה</button><button class="tab-button" data-tab="regulations">תקנון</button></div><div id="upcoming" class="tab-content">
        <div class="year-selector"><select style="margin-bottom:20px"><option>2026</option><option>2025</option></select></div>
        <div class="results-item"><div><strong>המשחק הבא</strong><br>מכבי חיפה vs הפועל חדרה</div><div>שבת, 18:00</div></div>
        <div class="results-item"><div><strong>משחק קרוב נוסף</strong><br>הפועל ת"א vs בית"ר ירושלים</div><div>ראשון, 20:45</div></div>
      </div>
      <div id="results" class="tab-content active"><div class="year-selector"><select><option>2026</option><option>2025</option><option>2024</option><option>2023</option><option>2022</option><option>2021</option></select></div>
        <div class="results-item"><div><strong>מכבי חיפה vs הפועל ת"א</strong><br>25 במרץ 2026</div><div class="score">3:1</div></div>
        <div class="results-item"><div><strong>בני יהודה vs בית"ר</strong><br>22 במרץ 2026</div><div class="score">2:2</div></div>
        <div class="results-item"><div><strong>הפועל חיפה vs מכבי נתניה</strong><br>19 במרץ 2026</div><div class="score">3:0</div></div>
      </div>
      <div id="gallery" class="tab-content">
        <div class="gallery-grid">
          <div class="gallery-item"><img src="https://images.unsplash.com/photo-1594471190262-59a3f4bd7d02?w=300&h=300&fit=crop" alt="תמונה" width="300" height="300" loading="lazy"></div>
          <div class="gallery-item"><img src="https://images.unsplash.com/photo-1560012057-4372e14c5085?w=300&h=300&fit=crop" alt="תמונה" width="300" height="300" loading="lazy"></div>
          <div class="gallery-item"><img src="https://images.unsplash.com/photo-1508344928928-7165b67de128?w=300&h=300&fit=crop" alt="תמונה" width="300" height="300" loading="lazy"></div>
        </div>
      </div>
      <div id="regulations" class="tab-content">
        <div class="regulations-text">
          <h3>כללי המשחק</h3>
          <p>כל משחק מורכב מ-10 פריימים. כל שחקן זורק שתי כדורים בכל פריים, למעט הפריים העשירי בו ניתן לזרוק עד שלושה כדורים בהתאם לתוצאה.</p>
          <h3>דרישות השתתפות</h3>
          <p>על כל קבוצה להירשם מראש ולהגיע עם מספר שחקנים תואם לתקנון הליגה.</p>
        </div>
      </div>
    </div><aside class="side-panel"><div class="ad-placeholder">פרסומת ימין</div></aside></div></main>
  <script is:inline>
    document.querySelectorAll('.tab-button').forEach(button => {
      button.addEventListener('click', function() {
        const tabName = this.dataset.tab;
        document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        this.classList.add('active');
        document.getElementById(tabName).classList.add('active');
      });
    });
  </script>
</BaseLayout>
