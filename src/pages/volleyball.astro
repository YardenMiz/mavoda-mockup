---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`כדורעף - העמותה לספורט`} description={`ליגת הכדורעף של העמותה לספורט מרחב חיפה והצפון — משחקים קרובים, תוצאות אחרונות וגלריה.`}>
<main class="container" data-sport="volleyball"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="left"></div></aside><div class="main-content">
    <a href="index.html" class="back-link">← חזרה למסך הבית</a>

    <div class="sport-detail-header">
      <h1>כדורעף</h1>
    </div>

    <div class="coordinator-info">
      <div class="coordinator-name">רכז: דוד כהן</div>
      <div class="coordinator-phone">טלפון: 050-1234567</div>
    </div>

    <div class="tabs-nav">
      <button class="tab-button active" data-tab="upcoming">משחקים הבאים</button><button class="tab-button active" data-tab="results">תוצאות אחרונות</button>
      <button class="tab-button" data-tab="gallery">גלריה</button>
      <button class="tab-button" data-tab="regulations">תקנון</button>
    </div>

    <!-- תוצאות אחרונות -->
    <div id="upcoming" class="tab-content">
        <div class="year-selector"><select style="margin-bottom:20px"><option>2026</option><option>2025</option></select></div>
        <div class="results-item"><div><strong>המשחק הבא</strong><br>מכבי חיפה vs הפועל חדרה</div><div>שבת, 18:00</div></div>
        <div class="results-item"><div><strong>משחק קרוב נוסף</strong><br>הפועל ת"א vs בית"ר ירושלים</div><div>ראשון, 20:45</div></div>
      </div>
      <div id="results" class="tab-content active">
      <div class="year-selector">
        <label for="year-select">בחר שנה:</label>
        <select id="year-select">
          <option value="2026">2026</option>
          <option value="2025">2025</option>
          <option value="2024">2024</option>
          <option value="2023">2023</option>
          <option value="2022">2022</option>
          <option value="2021">2021</option>
          <option value="2020">2020</option>
          <option value="2019">2019</option>
          <option value="2018">2018</option>
          <option value="2017">2017</option>
          <option value="2016">2016</option>
          <option value="2015">2015</option>
        </select>
      </div>

      <div class="results-item">
        <div>
          <div class="teams">מכבי חיפה vs הפועל ת"א</div>
          <div class="date">25 במרץ 2026</div>
        </div>
        <div class="score">3:2</div>
      </div>

      <div class="results-item">
        <div>
          <div class="teams">בני יהודה vs בית"ר</div>
          <div class="date">22 במרץ 2026</div>
        </div>
        <div class="score">2:2</div>
      </div>

      <div class="results-item">
        <div>
          <div class="teams">הפועל חיפה vs מכבי נתניה</div>
          <div class="date">19 במרץ 2026</div>
        </div>
        <div class="score">1:3</div>
      </div>

      <div class="results-item">
        <div>
          <div class="teams">עירוני חיפה vs מועדון הרצליה</div>
          <div class="date">16 במרץ 2026</div>
        </div>
        <div class="score">4:1</div>
      </div>
    </div>

    <!-- גלריה -->
    <div id="gallery" class="tab-content">
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?w=300&h=300&fit=crop" alt="תמונה 1" width="300" height="300" loading="lazy">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1494942286556-6370a9867bbf?w=300&h=300&fit=crop" alt="תמונה 2" width="300" height="300" loading="lazy">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=300&h=300&fit=crop" alt="תמונה 3" width="300" height="300" loading="lazy">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=300&h=300&fit=crop" alt="תמונה 4" width="300" height="300" loading="lazy">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1517836357463-d25ddfcbf042?w=300&h=300&fit=crop" alt="תמונה 5" width="300" height="300" loading="lazy">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1519167758481-83f19106048c?w=300&h=300&fit=crop" alt="תמונה 6" width="300" height="300" loading="lazy">
        </div>
      </div>
    </div>

    <!-- תקנון -->
    <div id="regulations" class="tab-content">
      <div class="regulations-text">
        <h3>כללי המשחק</h3>
        <p>
          הליגה מנוהלת לפי הכללים הבינלאומיים של FIVB (פדרציה בינלאומית לכדורעף).
          כל משחק מורכב משלוש סטות, והקבוצה הראשונה להגיע ל-25 נקודות בסט מנצחת את הסט (עם הפרש של לפחות 2 נקודות).
        </p>

        <h3>דרישות השתתפות</h3>
        <p>
          כל קבוצה חייבת להיות מורכבת מ-12-14 שחקנים רשומים.
          על כל קבוצה להציג מנהל קבוצה וקוצ'ים מוסמכים.
          דמי השתתפות חייבים להיות משולמים לפני תחילת העונה.
        </p>

        <h3>התנהגות ושיוך</h3>
        <p>
          על כל השחקנים להתנהג בכבוד לפי כללי ההתנהגות של הליגה.
          כל שחקן המביע התנהגות לא ספורטיבית יעברו משמעות תמיד לוועדת משמעות.
        </p>

        <h3>מחלוקות</h3>
        <p>
          כל מחלוקת יש להגיש בתוך 48 שעות מסיום המשחק.
          החלטות ועדת המשמעות סופיות ובלתי ניתנות לערעור.
        </p>
      </div>
    </div>
  </div><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="right"></div></aside></div></main>
<script is:inline>
    document.querySelectorAll('.tab-button').forEach(button => {
      button.addEventListener('click', function() {
        const tabName = this.dataset.tab;
        
        document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        
        this.classList.add('active');
        document.getElementById(tabName).classList.add('active');
      });
    });

    document.getElementById('year-select').addEventListener('change', function() {
      console.log('בחרת שנה: ' + this.value);
    });
  </script>
</BaseLayout>
