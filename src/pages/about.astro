---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`אודות — העמותה לספורט`} description={`אודות העמותה לספורט מרחב חיפה והצפון — מי אנחנו, המטרות שלנו והפעילות הענפית באזור.`}>
<Fragment slot="head">
  <style>
    .about-section {
      margin: 2rem 0;
      padding: 2rem;
      background: #f5f5f5;
      border-radius: 8px;
    }
    .about-content {
      max-width: 800px;
      margin: 0 auto;
    }
    .about-content h2 {
      color: #333;
      margin-bottom: 1rem;
      text-align: center;
    }
    .about-content p {
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .about-content ul {
      margin-bottom: 1rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }
    th {
      background-color: #f2f2f2;
    }
    .about-images-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin: 24px 0;
    }
    .about-image-card {
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    /* .about-image-placeholder / .about-person-img / figcaption are created by
       inlineEditor.js in JS, so they never get Astro's data-astro-cid
       attribute — scoped selectors would silently never match them. */
    :global(.about-image-placeholder),
    :global(.about-person-img) {
      width: 100%;
      height: 180px;
      border-radius: 10px;
    }
    :global(.about-image-placeholder) {
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px dashed #cbd5e1;
      background: #fff;
      color: #64748b;
      font-size: 14px;
      font-weight: 600;
    }
    :global(.about-person-img) {
      object-fit: contain;
      background: #fff;
      border: 1px solid #e5e7eb;
    }
    :global(.about-image-card figcaption) {
      font-weight: 700;
      color: #1f2937;
      text-align: center;
    }
    @media (max-width: 620px) {
      .about-images-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Fragment>

<main class="container main-grid"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="left"></div></aside><div class="main-content">
    <section class="hero"> 
      <img src="skin/design/hero.jpg" alt="כותרת" class="hero-img" width="851" height="315">
      <div class="hero-overlay">
        <h1 class="hero-title">אודות העמותה</h1>
        <p class="hero-lead">העמותה לספורט - מרחב חיפה והצפון</p>
      </div>
    </section>

    <div class="about-images-row" id="about-images-row">
      <figure class="about-image-card" data-slot="right"><div class="about-image-placeholder">תמונה</div><figcaption></figcaption></figure>
      <figure class="about-image-card" data-slot="center"><div class="about-image-placeholder">תמונה</div><figcaption></figcaption></figure>
      <figure class="about-image-card" data-slot="left"><div class="about-image-placeholder">תמונה</div><figcaption></figcaption></figure>
    </div>

    <div class="about-section">
      <div class="about-content" id="about-content">
        <h2 data-section="ceo_message"></h2>
        <div data-section-body="ceo_message"></div>

        <h2 data-section="goals"></h2>
        <ul data-section-body="goals"></ul>

        <h2 data-section="news"></h2>
        <div data-section-body="news"></div>

        <h2 data-section="history"></h2>
        <div data-section-body="history"></div>

        <h2>חברי הנהלה</h2>
        <table id="board-table">
          <thead>
            <tr><th>שם</th><th>תפקיד</th></tr>
          </thead>
          <tbody id="board-table-body"></tbody>
        </table>
      </div>
    </div>

  </div><aside class="side-panel"><div class="ad-placeholder" data-ad-slot="right"></div></aside></div></main>

<script>
  import { supabase } from '../lib/supabase.js';
  import {
    getEditContext,
    mountAboutSectionEditor,
    mountAboutBoardEditor,
    mountAboutImageEditor,
  } from '../lib/inlineEditor.js';

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str ?? '';
    return div.innerHTML;
  }

  async function refreshSections() {
    const { data } = await supabase.from('about_sections').select('*').order('sort_order');
    const sections = data || [];
    const ctx = await getEditContext();
    const isAdmin = ctx?.role === 'admin';

    sections.forEach((section) => {
      const heading = document.querySelector(`h2[data-section="${section.section_key}"]`);
      const bodyEl = document.querySelector(`[data-section-body="${section.section_key}"]`);
      if (heading) heading.textContent = section.heading;
      if (bodyEl) {
        const lines = (section.body || '').split('\n').filter((l) => l.trim());
        bodyEl.innerHTML = section.is_list
          ? lines.map((l) => `<li>${escapeHtml(l)}</li>`).join('')
          : lines.map((l) => `<p>${escapeHtml(l)}</p>`).join('');
      }
      if (isAdmin && heading) mountAboutSectionEditor(heading, section, refreshSections);
    });
  }

  async function refreshBoard() {
    const { data } = await supabase.from('about_board_members').select('*').order('sort_order');
    const members = data || [];
    const tbody = document.getElementById('board-table-body');
    tbody.innerHTML = members.map((m) => `
      <tr data-id="${m.id}"><td>${escapeHtml(m.name)}</td><td>${escapeHtml(m.role)}</td></tr>
    `).join('');

    const ctx = await getEditContext();
    if (ctx?.role === 'admin') {
      mountAboutBoardEditor(tbody, members, refreshBoard);
    }
  }

  async function refreshImages() {
    const { data } = await supabase.from('about_people_images').select('*');
    const bySlot = Object.fromEntries((data || []).map((row) => [row.slot, row]));
    const ctx = await getEditContext();
    const isAdmin = ctx?.role === 'admin';

    document.querySelectorAll('#about-images-row .about-image-card').forEach((figure) => {
      const slot = figure.dataset.slot;
      const row = bySlot[slot];
      const caption = figure.querySelector('figcaption');
      caption.textContent = row?.caption || '';

      const existingImg = figure.querySelector('.about-person-img');
      if (existingImg) existingImg.remove();
      const existingPlaceholder = figure.querySelector('.about-image-placeholder');
      if (existingPlaceholder) existingPlaceholder.remove();

      if (row?.image_url) {
        const img = document.createElement('img');
        img.src = row.image_url;
        img.alt = row.caption || '';
        img.className = 'about-person-img';
        figure.insertBefore(img, caption);
      } else {
        const placeholder = document.createElement('div');
        placeholder.className = 'about-image-placeholder';
        placeholder.textContent = 'תמונה';
        figure.insertBefore(placeholder, caption);
      }

      if (isAdmin) mountAboutImageEditor(figure, slot, row, refreshImages);
    });
  }

  refreshSections();
  refreshBoard();
  refreshImages();
</script>
</BaseLayout>
