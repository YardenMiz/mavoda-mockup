---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`העמותה לספורט - מרחב חיפה והצפון`} description={`העמותה לספורט במרחב חיפה והצפון — ליגות חובבים, תוצאות, לוחות זמנים והרשמה לענפי ספורט לכל הגילאים.`}>
<Fragment slot="head">
  <style>
    /* Desktop-only: shrinks the page 25% to fit more on screen. Left at
       natural 1:1 scale on mobile/tablet, where there's no spare width to
       spend on a zoom-out anyway. */
    @media (min-width: 901px) {
      main.container {
        zoom: 0.75;
      }
    }
    .header-actions {
      text-align: center;
    }
    .header-actions .search {
      width: 150px;
      background: #3ac41e;
      border: 1px solid #024616;
      color: #000;
      border-radius: 20px;
      padding: 8px 12px;
      font-size: 13px;
    }
    .header-actions .search option {
      color: #000;
      background: #fff;
    }
    .dropdown-menu {
      display: none !important;
    }
    .sports-layout {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      gap: 20px;
      margin-bottom: 40px;
    }
    /* Right column now only holds the photo carousel (news moved to the
       left column), enlarged to half of the fully-stretched size. */
    .right-column {
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .right-column .sidebar-section {
      flex: 0 1 auto;
      height: 60%;
    }
    /* main.container is zoomed 0.75x on this page only (desktop-only, see
       above), but the fixed strip+header (132px real) are outside that
       zoomed subtree, so the normal 132px margin-top renders as only 99px
       here and the ad boxes' top edge clips under the header. Compensate
       for the zoom — desktop-only, since mobile doesn't zoom. */
    @media (min-width: 901px) {
      .page-shell {
        margin-top: 184px;
      }
      /* Same zoom compensation: 50vh (the site-wide ad height) renders as
         37.5vh here unless scaled back up so the banner still reaches the
         middle of the real screen. Selector matches the shared rule's
         specificity (.page-shell > .side-panel .ad-placeholder) so this
         reliably wins instead of silently losing to the 50vh default. */
      .page-shell > .side-panel .ad-placeholder {
        height: 67vh;
      }
    }
    .right-column .image-carousel {
      flex: 1;
      height: auto;
    }
    @media (max-width: 900px) {
      .sports-layout {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      .right-column {
        height: auto;
      }
      .right-column .sidebar-section {
        height: auto;
      }
      .right-column .image-carousel {
        height: 220px;
      }
    }
    /* News sits below the notices list, each in its own distinct white
       card rather than sharing one continuous background. Notices is
       shrunk to ~66% less than its previous share of the shared height. */
    .left-column {
      display: flex;
      flex-direction: column;
      gap: 20px;
      background: none;
      padding: 0;
      box-shadow: none;
      border-radius: 0;
      align-self: start;
    }
    .notices-card {
      background: #fff;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      display: flex;
      flex-direction: column;
      flex: 0.5;
      min-height: 0;
    }
    .notices-scroll {
      flex: 1;
      overflow: hidden;
      position: relative;
      min-height: 300px;
    }
    .left-column .news-articles {
      flex: 0 0 auto;
      margin-top: 0;
      min-height: 0;
    }
    .notices-wrapper {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 0;
      width: 100%;
      animation: scroll-y 40s linear infinite; /* מהירות איטית וחלקה יותר */
    }
    .notices-wrapper:hover {
      animation-play-state: paused; /* עצירת הגלילה במעבר עכבר */
    }
    .notices-group {
      display: flex;
      flex-direction: column;
    }
    .notice-set {
      display: flex;
      flex-direction: column;
      gap: 15px;
      padding-bottom: 15px;
    }
    @keyframes scroll-y {
      0% { transform: translateY(-50%); }
      100% { transform: translateY(0); }
    }
    .notice-item {
      background: #f8f9fa;
      padding: 12px;
      border-radius: 8px;
      border-right: 4px solid #0b66ff;
    }
    #carousel-image {
      cursor: pointer;
    }
    .image-lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.85);
      z-index: 5000;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .image-lightbox[hidden] {
      display: none;
    }
    .image-lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }
    .image-lightbox-close {
      position: fixed;
      top: 20px;
      inset-inline-end: 24px;
      background: none;
      border: none;
      color: #fff;
      font-size: 36px;
      line-height: 1;
      cursor: pointer;
      z-index: 5001;
    }
  </style>
</Fragment>

