<script>
    import { supabase } from '../lib/supabase.js';
    import { getEditContext, mountSiteGalleryEditControls, mountNoticesAdmin, mountArticlesAdmin } from '../lib/inlineEditor.js';

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str ?? '';
      return div.innerHTML;
    }

    async function loadSiteGalleryRows() {
      return supabase.from('site_gallery').select('*').order('created_at', { ascending: false });
    }

    async function refreshSiteGalleryAdmin() {
      const adminContainer = document.getElementById('site-gallery-admin');
      if (!adminContainer) return;
      adminContainer.innerHTML = '';
      const { data } = await loadSiteGalleryRows();
      mountSiteGalleryEditControls(adminContainer, data || [], refreshSiteGalleryAdmin);
    }

    // --- Homepage notices (marquee) -----------------------------------------

    function buildNoticeSetHtml(notices) {
      return `<div class="notice-set">${notices.map((n) => `
        <div class="notice-item">
          <strong>${escapeHtml(n.title)}</strong>
          <p>${escapeHtml(n.body)}</p>
        </div>`).join('')}</div>`;
    }

    function buildNoticesGroupHtml(notices, ariaHidden) {
      const sets = [0, 1, 2].map(() => buildNoticeSetHtml(notices)).join('');
      return `<div class="notices-group"${ariaHidden ? ' aria-hidden="true"' : ''}>${sets}</div>`;
    }

    async function refreshNotices() {
      const wrapper = document.querySelector('.notices-wrapper');
      const adminContainer = document.getElementById('notices-admin');
      const { data } = await supabase.from('homepage_notices').select('*').order('sort_order');
      const notices = data || [];

      if (wrapper) {
        wrapper.innerHTML = notices.length
          ? buildNoticesGroupHtml(notices, false) + buildNoticesGroupHtml(notices, true)
          : '<div class="notices-group"><div class="notice-set"><div class="notice-item"><p>אין הודעות כרגע</p></div></div></div>';
      }

      const ctx = await getEditContext();
      if (adminContainer && ctx?.role === 'admin') {
        mountNoticesAdmin(adminContainer, notices, refreshNotices);
      }
    }

    // --- Homepage news articles ----------------------------------------------

    function renderArticles(articles) {
      const grid = document.querySelector('.articles-grid');
      if (!grid) return;
      grid.innerHTML = articles.map((a) => `
        <article class="article-card">
          <div class="article-source" style="background:${escapeHtml(a.badge_color)};color:#fff;display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:700;">${escapeHtml(a.badge_label)}</div>
          <h3>${a.url
            ? `<a href="${escapeHtml(a.url)}" target="_blank" rel="noopener" style="text-decoration:none;color:inherit;">${escapeHtml(a.title)}</a>`
            : escapeHtml(a.title)}</h3>
          <p>${escapeHtml(a.body)}</p>
          <time>${escapeHtml(a.time_label)}</time>
        </article>`).join('');
    }

    async function refreshArticles() {
      const adminContainer = document.getElementById('articles-admin');
      const { data } = await supabase.from('homepage_articles').select('*').order('sort_order');
      const articles = data || [];
      renderArticles(articles);

      const ctx = await getEditContext();
      if (adminContainer && ctx?.role === 'admin') {
        mountArticlesAdmin(adminContainer, articles, refreshArticles);
      }
    }

    document.addEventListener('DOMContentLoaded', async () => {
      refreshNotices();
      refreshArticles();
      const fallbackImages = [
        'skin/design/sec_bg.jpg',
        'skin/design/555.jpg',
        'skin/design/444.jpg'
      ];

      let images = fallbackImages;
      const { data } = await loadSiteGalleryRows();
      if (data && data.length) {
        images = data.map((row) => row.image_url);
      }

      const ctx = await getEditContext();
      if (ctx?.role === 'admin') {
        refreshSiteGalleryAdmin();
      }

      let currentIndex = 0;
      const carouselImage = document.getElementById('carousel-image');
      const prevBtn = document.querySelector('.prev-btn');
      const nextBtn = document.querySelector('.next-btn');

      function showImage(index) {
        carouselImage.src = images[index];
      }

      function nextImage() {
        currentIndex = (currentIndex + 1) % images.length;
        showImage(currentIndex);
      }

      function prevImage() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        showImage(currentIndex);
      }

      // Initial display
      showImage(currentIndex);

      // Event listeners
      prevBtn.addEventListener('click', prevImage);
      nextBtn.addEventListener('click', nextImage);

      // Lightbox: click the carousel image to view it centered/enlarged
      const lightbox = document.getElementById('image-lightbox');
      const lightboxImg = document.getElementById('image-lightbox-img');
      const lightboxClose = lightbox.querySelector('.image-lightbox-close');

      function openLightbox() {
        lightboxImg.src = carouselImage.src;
        lightbox.hidden = false;
      }
      function closeLightbox() {
        lightbox.hidden = true;
      }

      carouselImage.addEventListener('click', openLightbox);
      lightboxClose.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !lightbox.hidden) closeLightbox();
      });
    });
  </script>
</BaseLayout>
