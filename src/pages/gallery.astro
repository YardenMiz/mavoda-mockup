---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={`גלריות — בית ספורט`} description={`גלריית תמונות מפעילויות ואירועי הספורט של העמותה לספורט מרחב חיפה והצפון.`}>
<main class="container main-grid"><div class="page-shell"><aside class="side-panel"><div class="ad-placeholder">פרסומת שמאל</div></aside><div class="main-content">
    <section class="hero">
      <img src="skin/design/hero.jpg" alt="גלריות ספורט" class="hero-img" width="851" height="315">
      <div class="hero-overlay">
        <h1 class="hero-title">גלריות ספורט</h1>
        <p class="hero-lead">רגעים בלתי נשכחים מכל ענפי הספורט</p>
      </div>
    </section>

    <section class="leagues-categories" style="margin-bottom: 40px;">
      <a href="volleyball.html#gallery" class="league-category">
        <img src="skin/design/sports/volleyball.jpg" alt="כדורעף" width="170" height="80" loading="lazy">
        <span>כדורעף</span>
      </a>
      <a href="bowling.html#gallery" class="league-category">
        <img src="skin/design/sports/bowling.jpg" alt="באולינג" width="194" height="91" loading="lazy">
        <span>באולינג</span>
      </a>
      <a href="soccer.html#gallery" class="league-category">
        <img src="skin/design/sports/soccer.jpg" alt="כדורגל" width="194" height="91" loading="lazy">
        <span>כדורגל</span>
      </a>
      <a href="pingpong.html#gallery" class="league-category">
        <img src="skin/design/sports/pingpong.jpg" alt="טניס שולחן" width="194" height="91" loading="lazy">
        <span>טניס שולחן</span>
      </a>
      <a href="basketball.html#gallery" class="league-category">
        <img src="skin/design/sports/basketball.jpg" alt="כדורסל" width="350" height="200" loading="lazy">
        <span>כדורסל</span>
      </a>
      <a href="mountainbike.html#gallery" class="league-category">
        <img src="skin/design/sports/mountainbike.jpg" alt="אופני הרים" width="194" height="91" loading="lazy">
        <span>אופני הרים</span>
      </a>
      <a href="snooker.html#gallery" class="league-category">
        <img src="skin/design/sports/snooker.jpg" alt="סנוקר" width="170" height="80" loading="lazy">
        <span>סנוקר</span>
      </a>
      <a href="curling.html#gallery" class="league-category">
        <img src="skin/design/sports/curling.jpg" alt="קטרגל" width="170" height="80" loading="lazy">
        <span>קטרגל</span>
      </a>
      <a href="swimming.html#gallery" class="league-category">
        <img src="skin/design/sports/swimming.jpg" alt="שחייה" width="170" height="80" loading="lazy">
        <span>שחייה</span>
      </a>
      <a href="tennis.html#gallery" class="league-category">
        <img src="skin/design/sports/tennis.jpg" alt="טניס" width="194" height="91" loading="lazy">
        <span>טניס</span>
      </a>
      <a href="chess.html#gallery" class="league-category">
        <img src="skin/design/sports/chess.jpg" alt="שחמט" width="523" height="405" loading="lazy">
        <span>שחמט</span>
      </a>
      <a href="backgammon.html#gallery" class="league-category">
        <img src="skin/design/sports/backgammon.jpg" alt="שש בש" width="350" height="200" loading="lazy">
        <span>שש בש</span>
      </a>
      <a href="running.html#gallery" class="league-category">
        <img src="skin/design/sports/running.jpg" alt="ריצה" width="194" height="91" loading="lazy">
        <span>ריצה</span>
      </a>
      <a href="handball.html#gallery" class="league-category">
        <img src="skin/design/sports/handball.jpg" alt="כדורשת" width="350" height="200" loading="lazy">
        <span>כדורשת</span>
      </a>
      <a href="sup.html#gallery" class="league-category">
        <img src="skin/design/sports/sup.jpg" alt="סאפ תחרויות" width="194" height="91" loading="lazy">
        <span>סאפ תחרויות</span>
      </a>
      <a href="archery.html#gallery" class="league-category">
        <img src="skin/design/sports/archery.jpg" alt="ירי ספורטיבי" width="194" height="91" loading="lazy">
        <span>ירי ספורטיבי</span>
      </a>
      <a href="padel.html#gallery" class="league-category">
        <img src="skin/design/sports/padel.jpg" alt="פאדל" width="259" height="194" loading="lazy">
        <span>פאדל</span>
      </a>
    </section>

  </div><aside class="side-panel"><div class="ad-placeholder">פרסומת ימין</div></aside></div></main>
</BaseLayout>
